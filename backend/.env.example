PORT=8000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=quickappointment
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1d

# Optional home page API tuning
HOMEPAGE_FEATURED_LIMIT=6
HOMEPAGE_TESTIMONIALS_LIMIT=6
HOMEPAGE_CACHE_TTL_MS=60000

# Optional contact email notifications
CONTACT_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=notifications@example.com
SMTP_SECURE=false
